# ============================================================
# FRIDAY AI – Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!
# ============================================================

# LLM Provider API Keys (configure in-app via Settings panel)
# These are stored encrypted in the local database, not in .env
# The .env file is optional — all config can be done through the UI

# Optional: Override default port
# FRIDAY_PORT=47777

# Optional: Force a specific LLM provider on startup
# LLM_PROVIDER=openrouter
# LLM_MODEL=google/gemini-2.0-flash-001

# Note: API keys for LLM providers, web search (You.com),
# and email (SMTP) are configured through FRIDAY's Settings panel
# and stored encrypted in the local SQLite database using
# AES-256-GCM with a machine-specific key.
