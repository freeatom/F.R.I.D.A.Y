# ============================================================
# FRIDAY AI – .gitignore
# Comprehensive security-first Git exclusions
# ============================================================

# ==================== DEPENDENCIES ====================
node_modules/
package-lock.json

# ==================== DATABASES (CONTAIN USER SECRETS) ====================
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
data/

# ==================== ENVIRONMENT & SECRETS ====================
.env
.env.*
!.env.example
*.key
*.pem
*.cert
*.p12
*.pfx
*.jks

# ==================== BUILD OUTPUT ====================
dist/
out/
build/
*.exe
*.msi
*.dmg
*.AppImage
*.snap

# ==================== LOGS ====================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== OS FILES ====================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~

# ==================== EDITOR / IDE ====================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.editorconfig
*.code-workspace

# ==================== ELECTRON ====================
release/
*.asar
chrome-data/

# ==================== TEMP / CACHE ====================
tmp/
temp/
.cache/
*.tmp
*.bak

# ==================== FRIDAY-SPECIFIC SENSITIVE ====================
# User-specific data that should never be committed
friday_data/
backups/
exports/
